% ЗАДАНИЕ 2

% факты о животных
% Сначала перечисляем только всех кошек
cat('Бутси').
cat('Корни').
cat('Мактэвити').

% Затем перечисляем только всех собак
dog('Флэш').
dog('Ровер').
dog('Спот').

% Теперь перечисляем цвета всех животных подряд
color('Бутси', коричневый).
color('Корни', черный).
color('Мактэвити', рыжий).
color('Флэш', пятнистый).
color('Ровер', рыжий).
color('Спот', белый).

% правила
% Все кошки и собаки — животные
animal(Животное) :- cat(Животное).
animal(Животное) :- dog(Животное).

% владельцы
% Том владеет всеми черными и коричневыми животными
owns('Том', Питомец) :- animal(Питомец), color(Питомец, черный).
owns('Том', Питомец) :- animal(Питомец), color(Питомец, коричневый).

% Кейт владеет всеми собаками небелого цвета, которые не принадлежат Тому
owns('Кейт', Питомец) :- dog(Питомец), color(Питомец, Цвет), Цвет \= белый, \+ owns('Том', Питомец).

% Алан владеет Мактэвити, если Кейт не владеет Бутси и Спот без родословной
owns('Алан', 'Мактэвити') :- \+ owns('Кейт', 'Бутси'), \+ pedigree('Спот').

% родословная
% Все животные Тома и Кейт имеют родословные
pedigree(Питомец) :- owns('Том', Питомец).
pedigree(Питомец) :- owns('Кейт', Питомец).
